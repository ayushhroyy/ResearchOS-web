# Build-time environment for Next.js. These NEXT_PUBLIC_* values get baked
# into the client bundle at build time (`next build` / `opennextjs-cloudflare`).
#
# All values here are PUBLIC by design and safe to commit:
#   - the Supabase ANON key is RLS-protected (never the service_role key!)
#   - the app URL is public
#
# Runtime (server-side, non-NEXT_PUBLIC) vars live in wrangler.jsonc `vars`.
# Secrets live only in Cloudflare (wrangler secret put) and are NEVER here.

NEXT_PUBLIC_APP_URL=https://rabbitt-ai.youtopialabs.workers.dev
NEXT_PUBLIC_SUPABASE_URL=https://tybaqefujckkwdskztjp.supabase.co
