# ── aimlapi (LLM + vision + embeddings + OCR, OpenAI-compatible) ──────────────
# Dashboard: https://aimlapi.com  →  get an API key
AIMLAPI_BASE_URL=https://api.aimlapi.com/v1
AIMLAPI_KEY=your_aimlapi_key

# Model ids (defaults are sane free-tier choices — override per env if you like).
# - chat: must support tool/function calling for the agentic edit + web-search
#         loops. deepseek/deepseek-v4-flash supports it per aimlapi docs.
# - vision: used for OCR of images (any multimodal model on aimlapi)
# - ocr: document OCR model (mistral-ocr-latest / GLM-OCR)
# - embedding: dimension MUST match the pgvector column (default 1536
#   for text-embedding-3-small's full API output)
AIMLAPI_CHAT_MODEL=deepseek/deepseek-v4-flash
AIMLAPI_VISION_MODEL=deepseek/deepseek-v4-flash
AIMLAPI_OCR_MODEL=mistral-ocr-latest
AIMLAPI_EMBEDDING_MODEL=text-embedding-3-small
AIMLAPI_EMBEDDING_DIM=1536

# ── Supabase (Postgres + pgvector + Storage + Auth) ───────────────────────────
# Project: https://supabase.com  → create project, copy URLs + keys
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
# Service role — server only, bypasses RLS. NEVER expose to the client.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ── Serper (web search) ───────────────────────────────────────────────────────
# https://serper.dev  → 100 free queries/day on the free tier
SERPER_API_KEY=your_serper_key

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
